{
  "name": "hydronic-pump-head-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Professional Hydronic Pump Head (TDH) Calculator",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && vite build --mode singlefile",
    "preview": "vite preview",
    "preview:single": "vite preview --outDir dist-portable --port 5180 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^2.1.9"
  }
}
