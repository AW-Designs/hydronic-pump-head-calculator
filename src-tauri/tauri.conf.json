{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hydronic Pump Head Calculator",
  "version": "1.0.2",
  "identifier": "ca.lorenc.hydronic-pump-head-calculator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hydronic Pump Head Calculator",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFNjEwMjYzODQ4RkIxMDUKUldRRnNZK0VZd0podmpabUJacnp1c0h0NnlPbGplZysxekpsSHNCU2VKK0Nudzk5TFVvUzVyN1oK",
      "endpoints": [
        "https://github.com/AW-Designs/hydronic-pump-head-calculator/releases/latest/download/latest.json"
      ]
    }
  }
}
